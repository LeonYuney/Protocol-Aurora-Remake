# ==========================================
# UE5 FOLDERS (Generated/Build)
# ==========================================
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# UE5 Staged Builds & Packaging
Saved/StagedBuilds/
Saved/Stage/
Saved/Backup/
Saved/Logs/
Saved/VS/
Saved/Collada/
Saved/Cooked/

# Windows-specific builds
Binaries/Win*/
Build/Win*/
Saved/StagedBuilds/*/Windows*/

# ==========================================
# FILES (Executables & Generated)
# ==========================================
# Windows executables
*.exe
*.dll
*.pdb
*.lib
*.obj

# UE5 specific
*.ucas
*.utoc
*.pdt
*.pak
*.sym
*.exp

# Build artifacts
*.rsp
*.dep.json
*.VC.db
*.opensdf
*.sdf
*.suo
*.user
*.userosscache
*.sln.docstates
*.autosave

# OS Files
.DS_Store
Thumbs.db

# ==========================================
# SAVED FOLDER EXCEPTIONS (keep configs)
# ==========================================
!Saved/Config/
!Saved/SourceControl/

# ==========================================
# CONTENT & SHADERS
# ==========================================
Content/LocalData/
Content/Paks/
Saved/ShaderCache/

# ==========================================
# PLUGINS (binaries only)
# ==========================================
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/Saved/

